{
    "name": "emneslab/custom-meta-box-builder",
    "description": "A modern WordPress meta box builder with 30+ field types, visual admin UI, nested groups, conditional logic, REST API, Gutenberg sidebar, and WP-CLI support.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "meta-box",
        "custom-fields",
        "admin-ui",
        "field-builder",
        "post-meta",
        "taxonomy-meta",
        "user-meta",
        "gutenberg",
        "acf-alternative"
    ],
    "homepage": "https://github.com/emnesco/custom-meta-box-builder",
    "authors": [
        {
            "name": "EMNES Lab",
            "email": "bd.kabiruddin@gmail.com",
            "homepage": "https://emnes.co"
        }
    ],
    "support": {
        "issues": "https://github.com/emnesco/custom-meta-box-builder/issues",
        "source": "https://github.com/emnesco/custom-meta-box-builder"
    },
    "require": {
        "php": ">=8.1",
        "composer/installers": "^1.0 || ^2.0"
    },
    "conflict": {
        "php": "<8.1"
    },
    "autoload": {
        "psr-4": {
            "CMB\\": "src/"
        },
        "files": [
            "public-api.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2.6",
        "yoast/phpunit-polyfills": "^2.0",
        "antecedent/patchwork": "^2.1"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit tests/Unit/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
