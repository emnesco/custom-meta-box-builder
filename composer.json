{
    "name": "emneslab/custom-meta-box-builder",
    "description": "Modern WordPress custom meta box plugin with visual builder and PHP API",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "CMB\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2.6",
        "yoast/phpunit-polyfills": "^2.0",
        "antecedent/patchwork": "^2.1"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit tests/Unit/"
    },
    "minimum-stability": "stable",
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
